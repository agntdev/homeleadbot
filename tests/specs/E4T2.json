[
  {
    "name": "Full flow: agent creates listing, two buyers tap 'I'm interested' (one B, one A), then /digest lists the B lead",
    "steps": [
      {
        "send": {
          "update": {
            "update_id": 12001,
            "my_chat_member": {
              "chat": { "id": -100900600001, "type": "supergroup", "title": "Warm Digest Buyers" },
              "from": { "id": 20001, "is_bot": false, "first_name": "Alice" },
              "date": 0,
              "old_chat_member": { "user": { "id": 999, "is_bot": true, "first_name": "HomeLeadBot" }, "status": "left" },
              "new_chat_member": { "user": { "id": 999, "is_bot": true, "first_name": "HomeLeadBot" }, "status": "member" }
            }
          }
        },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": {
          "callback": "claim_group:-100900600001",
          "userId": 20001,
          "chatId": -100900600001,
          "messageId": 1
        },
        "expect": [{ "method": "answerCallbackQuery" }, { "method": "editMessageText" }]
      },
      {
        "send": { "text": "/create_listing", "userId": 20001, "chatId": 20001 },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "text": "T", "userId": 20001, "chatId": 20001 },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "text": "D", "userId": 20001, "chatId": 20001 },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "text": "1", "userId": 20001, "chatId": 20001 },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "text": "1", "userId": 20001, "chatId": 20001 },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "text": "SOMA", "userId": 20001, "chatId": 20001 },
        "expect": [
          { "method": "sendMessage" },
          { "method": "sendMessage" }
        ]
      },
      {
        "send": {
          "callback": "groups:create_listing:group:-100900600001",
          "userId": 20001,
          "chatId": 20001,
          "messageId": 2
        },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "sendMessage" }
        ]
      },
      {
        "send": {
          "callback": "groups:create_listing:done",
          "userId": 20001,
          "chatId": 20001,
          "messageId": 3
        },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "sendMessage" },
          { "method": "sendMessage" }
        ]
      },
      {
        "send": {
          "callback": "interested:1",
          "userId": 21001,
          "chatId": 21001,
          "messageId": 4
        },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "sendMessage" }
        ]
      },
      {
        "send": { "text": "L", "userId": 21001, "chatId": 21001 },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "text": "skip", "userId": 21001, "chatId": 21001 },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "text": "skip", "userId": 21001, "chatId": 21001 },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "text": "3-6m", "userId": 21001, "chatId": 21001 },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "text": "yes", "userId": 21001, "chatId": 21001 },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Thanks! Your lead has been recorded (lead #1, tier B \u2014 warm). The agent will reach out soon."
            }
          }
        ]
      },
      {
        "send": {
          "callback": "interested:1",
          "userId": 21002,
          "chatId": 21002,
          "messageId": 5
        },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "sendMessage" }
        ]
      },
      {
        "send": { "text": "L", "userId": 21002, "chatId": 21002 },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "text": "skip", "userId": 21002, "chatId": 21002 },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "text": "skip", "userId": 21002, "chatId": 21002 },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "text": "30d", "userId": 21002, "chatId": 21002 },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "text": "yes", "userId": 21002, "chatId": 21002 },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Thanks! Your lead has been recorded (lead #2, tier A \u2014 hot). The agent will reach out soon."
            }
          },
          { "method": "sendMessage" },
          { "method": "sendMessage" }
        ]
      },
      {
        "send": { "text": "/digest", "userId": 20001, "chatId": 20001 },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Warm-lead digest (last 24h, 1 lead):\n\u2022 lead #1 \u2014 Test (telegram id 21001)"
            }
          }
        ]
      }
    ]
  }
]
